#############################################
# Application Configuration
#############################################
# Logging configuration
LOG_LEVEL=DEBUG  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_DIR=data/outputs/logs/
ENABLE_CONSOLE_LOGGING=true
 MAX_DOCUMENTS_TO_PROCESS=5
# Processing strategy (options: identify, label, substitute)
ANONYMIZATION_MODE=identify
 
# Cloud service provider configuration
# Specifies which provider to use for LLM API calls
# Options:
# - openai    : OpenAI's API service (GPT models)
# - aws       : Amazon Bedrock service
# - azure     : Azure OpenAI service
# - google_ai_studio : Google AI Studio (Gemini models)
# - local     : Local models (requires separate setup)
CLOUD_PROVIDER=aws
 
# Models to use (comma-separated list)
# Available models aws:
# - claude-3.7-sonnet
# - claude-3.7-haiku
# Available models openai:
# - gpt-4.1
# - gpt-o4-mini
# Available models local:
# - llama-3.1-8b
# - llama-3.1-70b
# - llama-3.1-405b
# - llama-3.2-1b
# - llama-3.2-3b
# - llama-3.3-8b
# - llama-3.3-70b
# - llama-4 #TODO: Check if this is correct
# - gemma-3-1b
# - gemma-3-4b
# - qwen-3-1.7b
# Availables models azure:
# - deepseek-r1
# - deepseek-v3-0324
# - deepseek-v3
# Available models google_ai_studio:
# - gemini-2.5-flash
# - gemini-2.0-flash
# - gemini-2.5-pro
MODELS=claude-3.7-sonnet

# File paths
INPUT_DIR=data/inputs/
OUTPUT_DIR=data/outputs/
METRICS_DIR=data/outputs/metrics/
DEBUG_DIR=data/outputs/debug/
 
#############################################
# LLM Configuration
#############################################
# Model parameters
#TEMPERATURE
# - 0.0: deterministic output
# - 1.0: random output (default)
TEMPERATURE=1.0
# Maximum number of tokens to generate
# - 0: no limit
# - 2048: 2k tokens 
# - 2500: 2,5k tokens (default)
MAX_TOKENS=4096
# Top-p sampling (nucleus sampling)
# - 0.0: no limit
# - 1.0: all tokens (default)
TOP_P=1.0 
# Top-k sampling
# - 0: no limit (default)
# - 50: top 50 tokens
TOP_K=0
# Number of best tokens to keep
# - 0: no limit (default)
# - 1: only the best token
FREQUENCY_PENALTY=0.0
#Presence penalty
# - 0.0: no penalty (default)
# - 1.0: strong penalty 
PRESENCE_PENALTY=0.0
 
#############################################
# OpenAI Configuration
#############################################
# API Key (keep secure, never commit actual key)
OPENAI_API_KEY=
 
#############################################
# AWS Configuration
#############################################
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SECRET_TOKEN=

# AWS Rate Limiting and Retry Configuration
# Maximum number of retries for throttling errors
AWS_MAX_RETRIES=5
# Base delay in seconds for exponential backoff
AWS_BASE_DELAY=1.0
# Maximum delay in seconds between retries
AWS_MAX_DELAY=60.0
# Delay between consecutive requests in seconds
AWS_REQUEST_DELAY=0.1
 
#############################################
# Azure Configuration
#############################################
AZURE_ENDPOINT=https://text-example.services.ai.azure.com/models
AZURE_SUBSCRIPTION_ID=

#############################################
# Google Cloud Configuration
#############################################
GOOGLE_AI_STUDIO_API_KEY=

#############################################
# Ollama Configuration
#############################################
OLLAMA_BASE_URL=http://localhost:11434