#############################################
# Application Configuration
#############################################
# Logging configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_DIR=logs/
ENABLE_CONSOLE_LOGGING=true

# Processing strategy (options: label, substitute)
ANONYMIZATION_MODE=label

# Cloud service provider (options: aws, azure, local)
CLOUD_PROVIDER=aws

# Models to use (comma-separated list)
MODELS=claude-3.7-sonnet,claude-3-haiku

# File paths
INPUT_DIR=data/inputs/
OUTPUT_DIR=data/outputs/
METRICS_DIR=data/outputs/metrics/
DEBUG_DIR=data/outputs/debug/

#############################################
# OpenAI Configuration
#############################################
# API Key (keep secure, never commit actual key)
OPENAI_API_KEY=your_openai_api_key

# Model Selection
OPENAI_MODEL=gpt-3.5-turbo

#############################################
# AWS Configuration
#############################################
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

#############################################
# Azure Configuration
#############################################
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
