#############################################
# Application Configuration
#############################################
# Logging configuration
LOG_LEVEL=DEBUG  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_DIR=data/outputs/debug/logs/
ENABLE_CONSOLE_LOGGING=true
FIRST_DOCUMENT_TO_PROCESS=0
MAX_DOCUMENTS_TO_PROCESS=2000
# Processing strategy (options: identify, label, substitute, pseudo)
ANONYMIZATION_MODE=label
 
# Cloud service provider configuration
# Specifies which provider to use for LLM API calls
# Options:
# - openai         : OpenAI's API service (GPT models)
# - aws            : Amazon Bedrock service
# - azure          : Azure OpenAI service
# - google_ai_studio : Google AI Studio (Gemini models via Developer API)
# - vertex_ai      : Google Cloud Vertex AI (Gemini models on GCP)
# - local          : Local models (requires separate setup) - OLLAMA
CLOUD_PROVIDER=local
 
# Models to use (comma-separated list)
# Available models aws:
# - claude-3.7-sonnet
# - claude-3.7-haiku
# - claude-4.0-sonnet
# Available models openai:
# - gpt-4.1
# - gpt-o4-mini
# Available models local:
# - llama-3.1-8b
# - llama-3.1-70b
# - llama-3.1-405b
# - llama-3.2-1b
# - llama-3.2-3b
# - llama-3.3-8b
# - llama-3.3-70b
# - llama-4 #TODO: Check if this is correct
# - gemma-3-1b
# - gemma-3-4b
# - gemma-3-27b
# - qwen-3-1.7b
# Availables models azure:
# - deepseek-r1
# - deepseek-v3-0324
# - deepseek-v3
# Available models google_ai_studio:
# - gemini-2.5-flash
# - gemini-2.0-flash
# - gemini-2.5-pro
# Available models vertex_ai:
# - gemini-2.5-flash      (preview, fast and efficient)
# - gemini-2.5-pro        (preview, most capable)
# - gemini-2.0-flash      (stable, production-ready)
# - gemini-1.5-pro        (stable, balanced performance)
# - gemini-1.5-flash      (stable, fast responses)
MODELS=gemma-3-27b

# File paths
INPUT_DIR=data/inputs/
OUTPUT_DIR=data/outputs/
METRICS_DIR=data/outputs/metrics/
DEBUG_DIR=data/outputs/debug/
 
#############################################
# LLM Configuration
#############################################
# Model parameters optimizados para Llama 3.3-70B
#TEMPERATURE
# - 0.0: deterministic output
# - 1.0: random output (default)
TEMPERATURE=0
# Maximum number of tokens to generate
# - 0: no limit
# - 2048: 2k tokens 
# - 2500: 2,5k tokens (default)
MAX_TOKENS=800000
# Top-p sampling (nucleus sampling)
# - 0.0: no limit
# - 1.0: all tokens (default)
TOP_P=1
# Top-k sampling
# - 0: no limit (default)
# - 50: top 50 tokens
TOP_K=0
# Number of best tokens to keep
# - 0: no limit (default)
# - 1: only the best token
FREQUENCY_PENALTY=0.0
#Presence penalty
# - 0.0: no penalty (default)
# - 1.0: strong penalty 
PRESENCE_PENALTY=0.0
 
#############################################
# OpenAI Configuration
#############################################
# API Key (keep secure, never commit actual key)
OPENAI_API_KEY=
 
#############################################
# AWS Configuration
#############################################
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

AWS_CONNECT_TIMEOUT=
AWS_READ_TIMEOUT=
AWS_MAX_RETRIES=
AWS_BASE_DELAY=
AWS_MAX_DELAY=
AWS_REQUEST_DELAY=
AWS_MIN_REQUEST_INTERVAL=


#############################################
# Azure Configuration
#############################################
AZURE_ENDPOINT=
AZURE_SUBSCRIPTION_ID=
AZURE_TIMEOUT=

#############################################
# Google Cloud Configuration
#############################################
# Google AI Studio (Simple API key - get from https://aistudio.google.com/apikey)
GOOGLE_AI_STUDIO_API_KEY=

# Vertex AI (GCP - requires OAuth via gcloud or service account)
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
# Optional: Path to service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

#############################################
# Ollama Configuration
#############################################
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=300