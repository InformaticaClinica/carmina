#############################################
# Application Configuration
#############################################
# Logging configuration
DEBUG_ENABLED=false
LOG_LEVEL=DEBUG  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=%(asctime)s - %(threadName)s [%(task_id)s] - %(name)s - %(levelname)s - %(message)s
LOG_DIR=data/outputs/debug/logs/
ENABLE_CONSOLE_LOGGING=true
FIRST_DOCUMENT_TO_PROCESS=0
MAX_DOCUMENTS_TO_PROCESS=2000
# Parallel processing configuration
# MAX_WORKERS: Number of documents to process simultaneously (1 = sequential, 2+ = parallel)
# Recommended: 2-3 for Google AI Studio/Vertex AI to avoid rate limits
MAX_WORKERS=1
# Processing strategy (options: identify, label, substitute, pseudo)
ANONYMIZATION_MODE=label

# Default model settings used by src/carmina/config.py
DEFAULT_MODEL=qwen-3.5-122b
DEFAULT_TEMPERATURE=0
DEFAULT_MAX_TOKENS=8192
 
# Cloud service provider configuration
# Specifies which provider to use for LLM API calls
# Options:
# - openai         : OpenAI's API service (GPT models)
# - aws            : Amazon Bedrock service
# - azure          : Azure OpenAI service
# - google_ai_studio : Google AI Studio (Gemini models via Developer API)
# - vertex_ai      : Google Cloud Vertex AI (Gemini models on GCP)
# - local          : Local Ollama instance (localhost, no auth, with watchdog)
# - ollama         : Remote Ollama API (hosted endpoint, requires API key)
CLOUD_PROVIDER=ollama
 
# Models to use (comma-separated list)
# Available models aws:
# - claude-3.7-sonnet
# - claude-3.7-haiku
# - claude-4.5-sonnet
# - claude-4.5-haiku
# - claude-sonnet-4-6        (cross-region inference profile eu-west-1)
# - claude-opus-4-6          (cross-region inference profile eu-west-1)
# Available models openai:
# - gpt-4.1
# - gpt-o4-mini
# Available models local / ollama:
# Note: some models return implicit thinking/chain-of-thought which is
# automatically stripped from output and logged at DEBUG level.
# Qwen 3.5  (ollama API: qwen3.5:397b confirmed; smaller tags may vary)
# - qwen-3.5-397b
# - qwen-3.5-122b
# - qwen-3.5-35b
# - qwen-3.5-27b
# Qwen 3-next
# - qwen-3-next-80b
# Gemma 4  (ollama API: gemma4:31b confirmed)
# - gemma-4-31b
# - gemma-4-26b
# Gemma 3
# - gemma-3-27b
# - gemma-3-12b
# - gemma-3-4b
# GLM  (glm-5.1 and glm-5 may return implicit thinking)
# - glm-5.1
# - glm-5
# - glm-4.7
# - glm-4.6
# MiniMax  (minimax-m2.7 may return implicit thinking)
# - minimax-m2.7
# - minimax-m2.5
# - minimax-m2.1
# - minimax-m2
# Llama
# - llama-3.1-8b
# - llama-3.1-70b
# - llama-3.3-70b
# - llama-4
# - llama-4-scout
# GPT-OSS
# - gpt-oss-20b
# - gpt-oss-120b
# DeepSeek
# - deepseek-v3.2
# - deepseek-v3.1-671b
# Kimi
# - kimi-k2-1t
# - kimi-k2.5
# - kimi-k2-thinking
# Available models azure:
# - deepseek-r1
# - deepseek-v3-0324
# - deepseek-v3
# Available models google_ai_studio:
# - gemini-2.5-flash
# - gemini-2.0-flash
# - gemini-2.5-pro
# - gemini-3.1-pro-preview
# Available models vertex_ai:
# - gemini-3.1-pro-preview (latest, global location only)
# - gemini-2.5-flash       (preview, fast and efficient)
# - gemini-2.5-pro         (preview, most capable)
# - gemini-2.0-flash       (stable, production-ready)
# - gemini-1.5-pro         (stable, balanced performance)
# - gemini-1.5-flash       (stable, fast responses)
MODELS=qwen-3.5-122b

# File paths
INPUT_DIR=data/inputs/
OUTPUT_DIR=data/outputs/
METRICS_DIR=data/outputs/metrics/
DEBUG_DIR=data/outputs/debug/

# Text processing
MAX_CHUNK_SIZE=100  # Maximum chunk size in words for text processing
 
#############################################
# LLM Configuration
#############################################
# Model parameters optimizados para Llama 3.3-70B
#TEMPERATURE
# - 0.0: deterministic output
# - 1.0: random output (default)
TEMPERATURE=0
# Maximum number of tokens to generate
# - 2048: 2k tokens
# - 8192: 8k tokens (safe default for most providers)
# - 65536: max for Vertex AI gemini-3.1-pro-preview
# Note: Vertex AI enforces a hard cap of 65536
MAX_TOKENS=8192
# Top-p sampling (nucleus sampling)
# - 0.0: no limit
# - 1.0: all tokens (default)
TOP_P=1
# Top-k sampling
# - 0: no limit (default)
# - 50: top 50 tokens
TOP_K=0
# Number of best tokens to keep
# - 0: no limit (default)
# - 1: only the best token
FREQUENCY_PENALTY=0.0
#Presence penalty
# - 0.0: no penalty (default)
# - 1.0: strong penalty 
PRESENCE_PENALTY=0.0

# Thinking / chain-of-thought mode
# Add the "-think" suffix to the model name in MODELS to enable thinking for that model.
# The suffix is stripped internally so it never reaches the API or output file names.
# e.g.  MODELS=qwen-3.5-122b-think,qwen-3.5-122b,gemma-4-31b-think,gemma-4-31b
 
#############################################
# OpenAI Configuration
#############################################
# API Key (keep secure, never commit actual key)
OPENAI_API_KEY=
 
#############################################
# AWS Configuration
#############################################
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=

AWS_CONNECT_TIMEOUT=60
AWS_READ_TIMEOUT=120
AWS_MAX_RETRIES=5
AWS_BASE_DELAY=2.0
AWS_MAX_DELAY=120.0
AWS_REQUEST_DELAY=1.0
AWS_MIN_REQUEST_INTERVAL=0


#############################################
# Azure Configuration
#############################################
AZURE_ENDPOINT=
AZURE_SUBSCRIPTION_ID=
AZURE_TIMEOUT=300

#############################################
# Google Cloud Configuration
#############################################
# For Google AI Studio (simple API key - get from https://aistudio.google.com/apikey)
GOOGLE_AI_STUDIO_API_KEY=

# For Vertex AI (requires GCP project and service account)
# VERTEX_LOCATION: use 'global' for gemini-3.1-pro-preview, 'us-central1' for older models
VERTEX_PROJECT_ID=
VERTEX_LOCATION=global
# Path to service account JSON key file (absolute path recommended)
# Can also be set system-wide with: setx GOOGLE_APPLICATION_CREDENTIALS "C:\path\to\key.json"
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

#############################################
# Ollama Configuration (local instance)
#############################################
# Used when CLOUD_PROVIDER=local
OLLAMA_BASE_URL=http://localhost:11434
# Shared by CLOUD_PROVIDER=local and CLOUD_PROVIDER=ollama
OLLAMA_REQUEST_TIMEOUT=300
OLLAMA_RESTART_WAIT=12
OLLAMA_MAX_RETRIES=3

#############################################
# Ollama API Configuration (remote / hosted)
#############################################
# Used when CLOUD_PROVIDER=ollama
OLLAMA_API_URL=https://api.ollama.com
OLLAMA_API_KEY=
