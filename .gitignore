# Data directory
# Keep the expected folder skeleton in Git, but never commit datasets,
# generated outputs, logs, metrics, or local corpus files.
data/*
data/**/*
!data/**/
!data/**/.gitkeep
!data/README.md

# Python cache files
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# Mac OS files
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Virtual environment
venv/
ENV/
env/
.env

# IDEs and editors
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath

# Distribution / packaging
dist/
build/
*.egg-info/

# Jupyter Notebook
.ipynb_checkpoints

# Logs
*.log
logs/

# Local configuration
*.local.py
local_settings.py

# Google Cloud service account keys
secrets/
*.json

# Keep data log placeholders visible despite the generic logs/ rule above.
!data/outputs/logs/
!data/outputs/logs/.gitkeep
!data/outputs/debug/logs/
!data/outputs/debug/logs/.gitkeep
